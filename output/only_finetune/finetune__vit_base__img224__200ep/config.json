  REMODE: pixel
  RECOUNT: 1
  MIXUP: 0.8
  CUTMIX: 1.0
  CUTMIX_MINMAX: null
  MIXUP_PROB: 1.0
  MIXUP_SWITCH_PROB: 0.5
  MIXUP_MODE: batch
TEST:
  CROP: true
AMP_OPT_LEVEL: O0
OUTPUT: output/only_finetune/finetune__vit_base__img224__200ep
TAG: finetune__vit_base__img224__200ep
SAVE_FREQ: 5
