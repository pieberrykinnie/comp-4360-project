BASE:
- ''
DATA:
  BATCH_SIZE: 116
  DATA_PATH: ''
  CSV_PATH: ''
  IMG_ROOT: data/
  TRAIN_CSV_PATH: data/CheXpert-v1.0-small/train.csv
  VAL_CSV_PATH: data/CheXpert-v1.0-small/valid.csv
  UNCERTAINTY_POLICY: zeros
  FRONTAL_ONLY: true
  DATASET: imagenet
  IMG_SIZE: 224
  INTERPOLATION: bicubic
  PIN_MEMORY: true
  NUM_WORKERS: 8
  MASK_PATCH_SIZE: 32
  MASK_RATIO: 0.6
MODEL:
  TYPE: vit
  NAME: only_finetune
  RESUME: ''
  NUM_CLASSES: 1000
  DROP_RATE: 0.0
  DROP_PATH_RATE: 0.1
  LABEL_SMOOTHING: 0.1
  SWIN:
    PATCH_SIZE: 4
    IN_CHANS: 1
    EMBED_DIM: 96
    DEPTHS:
    - 2
    - 2
    - 6
    - 2
    NUM_HEADS:
    - 3
    - 6
    - 12
    - 24
    WINDOW_SIZE: 7
    MLP_RATIO: 4.0
    QKV_BIAS: true
    QK_SCALE: null
    APE: false
    PATCH_NORM: true
  VIT:
    PATCH_SIZE: 16
    IN_CHANS: 1
    EMBED_DIM: 768
    DEPTH: 12
    NUM_HEADS: 12
    MLP_RATIO: 4
    QKV_BIAS: true
    INIT_VALUES: 0.1
    USE_APE: false
    USE_RPB: true
    USE_SHARED_RPB: false
    USE_MEAN_POOLING: true
TRAIN:
  START_EPOCH: 0
  EPOCHS: 200
  WARMUP_EPOCHS: 20
  WEIGHT_DECAY: 0.05
  BASE_LR: 0.0090625
  WARMUP_LR: 1.8125e-06
  MIN_LR: 1.8125e-06
