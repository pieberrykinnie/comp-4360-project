    MULTISTEPS: []
  OPTIMIZER:
    NAME: adamw
    EPS: 1.0e-08
    BETAS:
    - 0.9
    - 0.999
    MOMENTUM: 0.9
  LAYER_DECAY: 0.65
AUG:
  COLOR_JITTER: 0.4
  AUTO_AUGMENT: rand-m9-mstd0.5-inc1
